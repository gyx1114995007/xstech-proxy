PORT=3000
HOST=0.0.0.0
API_KEY=sk-your-secret-key-here
XSTECH_ACCOUNTS='[{"account":"your@email.com","password":"your-password"}]'
XSTECH_BASE_URL=https://xstech.one
XSTECH_APP_VERSION=3.1.0
SESSION_POOL_SIZE=10
SESSION_MAX_IDLE_SEC=600
MODEL_REFRESH_INTERVAL_SEC=1800
TOKEN_REFRESH_BEFORE_SEC=300
LOG_LEVEL=DEBUG

# 默认 false：对齐 xstech 前端抓包，带文件请求不额外发送 useImages/useFiles。
# 如需调试旧行为，可显式设置为 true。
XSTECH_SEND_FILE_FLAGS=false
